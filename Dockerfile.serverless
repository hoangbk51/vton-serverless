FROM runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404
WORKDIR /app

COPY . /app

RUN pip install --upgrade pip
RUN pip install -e .
RUN pip install -r requirements-serverless.txt
RUN python scripts/download_weights.py --weights-dir /app/weights

ENV LD_LIBRARY_PATH=/usr/local/lib/python3.11/dist-packages/nvidia/cudnn/lib:$LD_LIBRARY_PATH
ENV WEIGHTS_DIR=/app/weights

CMD ["python", "-u", "handler.py"]
